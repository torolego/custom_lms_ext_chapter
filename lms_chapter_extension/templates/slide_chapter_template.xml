<odoo>
    <template id="slide_chapter_template" name="Slide Chapter Page">
        <t t-call="website.layout">
            <div class="container">
                <h1><t t-esc="chapter.name"/></h1>
                <p><t t-esc="chapter._description"/></p>

                <h3>Lessons:</h3>
                <ul>
                    <t t-foreach="chapter.lesson_ids" t-as="lesson">
                        <li>
                            <a t-att-href="'/slides/lesson/%s' % lesson.id">
                                <t t-esc="lesson.name"/>
                            </a>
                        </li>
                    </t>
                </ul>
            </div>
        </t>
    </template>
</odoo>


